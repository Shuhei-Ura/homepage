    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <script src="/js/main.js"></script>
    {{{ descriptions }}}
    {{{ styles }}}    <!-- ページ専用のCSSをここに挿入できる -->
    {{{ titles }}}
