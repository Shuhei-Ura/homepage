<body>
    <header class="site-header">
        <div class="header-container">
            <div class="logo">
                <a href="/"><img src="/images/company-logo-removebg-preview.png" alt="株式会社Respoint Okinawaのロゴ"></a>
            </div>
                <nav class="nav-menu">
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/blog-list">Blog</a></li>
                        <li><a href="/demo">Demo</a></li>
                        <li><a href="/recruit">Recruit</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </nav>
        </div>
    </header>
    <!-- スマホ用ヘッダー -->
    <header class="mobile-header" aria-label="Mobile Navigation">

        <!-- チェックボックスを header 直下へ移動 -->
        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />

        <div class="mobile-header__inner">
            <a class="mobile-logo" href="/"><img src="/images/company-logo-removebg-preview.png" alt="株式会社Respoint Okinawaのロゴ"></a>
            <label class="hamburger" for="nav-toggle" aria-label="メニューを開閉" aria-controls="mobile-nav">
            <span></span><span></span><span></span>
            </label>
        </div>

        <!-- これは header 直下のままでOK（input の“後ろ”にあることが重要） -->
        <div id="mobile-nav" class="mobile-nav-overlay" role="dialog" aria-modal="true">
            <label class="overlay-close" for="nav-toggle" aria-label="閉じる"></label>
              <!-- 右上のCLOSEボタン -->
            <label class="overlay-close-btn" for="nav-toggle" aria-label="閉じる">CLOSE</label>
            <nav class="mobile-nav">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/blog-list">Blog</a></li>
                    <li><a href="/demo">Demo</a></li>
                    <li><a href="/recruit">Recruit</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>   
    {{{body}}}
