{{#section "scripts"}}
  <script src="/js/home.js"></script>
{{/section}}

<!-- SEO用のh1　非表示 -->
<h1 class="sr-only">沖縄で未経験からエンジニアへ｜ゼロから始めるITキャリア｜Respoint Okinawa</h1>

<!-- home heroセクション -->
<section class="hero" aria-labelledby="hero-title">
  <div class="hero__slides">
    <!-- スライド1 -->
    <div class="hero__slide">
      <img src="/images/hero1.png" alt="沖縄で未経験からエンジニアやプログラマーを目指す文系・第二新卒の若手がキャリアの第一歩を踏み出すイメージ｜那覇での求人・研修付き採用情報">
    </div>
    <!-- スライド2 -->
    <div class="hero__slide">
      <img src="/images/hero2.png" alt="那覇の街並みから全国へ挑戦する若手エンジニア育成企業｜沖縄で未経験・文系からでも応募できるSES求人と研修採用支援">
    </div>
    <!-- スライド3 -->
    <div class="hero__slide">
      <img src="/images/hero3.png" alt="ノートPCで学習する若手未経験者がエンジニア・プログラマーとして成長する姿｜沖縄 那覇の求人・研修付き採用で文系からでもITキャリアを実現">
    </div>

    <!-- オーバーレイ -->
    <div class="hero__veil" aria-hidden="true"></div>

    <!-- キャッチコピー -->
    <h2 id="hero-title" class="hero__title">
      沖縄で未経験からエンジニアへ<br>
      キャリアの第一歩を、今。
    </h2>
  </div>
</section>

<!-- aboutの導線 -->
<section class="section-lead" aria-labelledby="about-lead-title">
  <div class="section-lead__text">
    <h2 id="about-lead-title" class="section-lead__title">私たちについて</h2>
    <p class="section-lead__desc">
      「自分にも価値がある」「挑戦してよかった」―― <br>
      そう思える経験は、人生に大きな自信と幸福をもたらします。
    </p>
    <p class="section-lead__desc">
      私たちは未経験からエンジニアに挑戦する若手に、その実感を届けたい。<br>
      ここからキャリアを始める人が、未来に希望を持てるよう全力で支援します。
    </p>
    <div class="section-lead__actions">
        <a href="/about" class="btn-readmore">READ MORE</a>
    </div>
  </div>

  <figure class="section-lead__media">
    <img
      src="/images/about-img.png"
      alt="沖縄から全国へ挑戦する若手エンジニアが未来を見据え、都会のビルを見上げるイメージ｜未経験からの成長とキャリア形成"
      width="1600" height="900" loading="lazy" decoding="async">
    <img src="/images/whats-next.png" alt="" class="lead-deco lead-deco--about" aria-hidden="true">
  </figure>

</section>

<!-- recruitの導線 -->
<section class="section-lead section-lead--recruit" aria-labelledby="recruit-lead-title">
  <figure class="section-lead__media">
    <img
      src="/images/recruit-img.png"
      alt="沖縄・那覇で未経験からエンジニアを目指す若手が、PCやスマホから求人に応募する様子｜研修付き採用で文系からでも安心してキャリアをスタートできる"
      width="1600" height="900" loading="lazy" decoding="async">
    <img src="/images/step-forward.png" alt="" class="lead-deco lead-deco--recruit" aria-hidden="true">
  </figure>

  <div class="section-lead__text">
    <h2 id="recruit-lead-title" class="section-lead__title">未経験エンジニア積極採用中</h2>
    <p class="section-lead__desc">
      「新しいことに挑戦したい」その気持ちさえあれば大丈夫。文系出身や社会人経験が浅い方も歓迎します。あなたのエントリーをお待ちしています。
    </p>
    <p class="section-lead__desc">
      「どんなカリキュラムで学べるのか」「どのように成長していけるのか」を知りたい方は、Recruitページをご覧ください。<br>
      あなたの挑戦に寄り添い、学びから現場デビューまで丁寧にサポートします。
    </p>
    <div class="section-lead__actions">
      <a href="/recruit" class="btn-readmore">Recruitページへ</a>
    </div>
  </div>
</section>

<!-- Zoho の導線 -->
<section class="section-lead section-lead--demo" aria-labelledby="demo-lead-title">
  <div class="section-lead__text">
    <h2 id="demo-lead-title" class="section-lead__title">Zohoで、業務改善を進めやすく</h2>
    <p class="section-lead__desc">
      顧客管理や問い合わせ管理、社内共有など、Zohoを活用した業務改善のご相談にも対応しています。<br>
      導入前の整理から構築、運用改善まで、現場に合った形でサポートします。
    </p>
  </div>
  <figure class="section-lead__media">
    <a href="https://respoint.zohosites.com/"><img
      src="/images/Zoho.png"
      alt="Zohoでの業務改善ページ"
      width="1600" height="800" loading="lazy" decoding="async">
    </a>
  </figure>
</section>

<!-- 事業紹介セクション -->
<section class="business" aria-labelledby="business-title">
  <div class="business__container">
    <h2 id="business-title" class="section-lead__title">事業内容</h2>

    <div class="business__grid">
      <!-- SES事業 -->
      <article class="business-card">
        <figure class="business-card__media">
          <img src="/images/introduce-ses.png"
               alt="沖縄を拠点に若手エンジニアがSESプロジェクトに参加し、PCやモニターで実務に取り組む様子｜未経験からの研修後に全国で活躍できるSES求人・採用情報">
          <h3 class="business-card__heading">システム開発事業</h3>
        </figure>
        <p class="business-card__desc">
          沖縄を拠点にシステム開発・運用プロジェクトへエンジニアを参画させています。<br>
          一人ひとりのスキルや志向に合わせた配属で、現場で実践的な経験を積みながら成長できる環境を提供。<br>
          お客様には即戦力となる人材を、エンジニアには長期的なキャリア形成を支援する仕組みを整えています。
        </p>
      </article>

      <!-- 教育事業 -->
      <article class="business-card">
        <figure class="business-card__media">
          <img src="/images/introduce-education.png"
               alt="未経験や文系出身の若手が沖縄・那覇で研修に参加し、ノートやPCを使って学び合う様子｜エンジニア・プログラマー育成の教育事業と求人採用支援">
          <h3 class="business-card__heading">教育事業</h3>
        </figure>
        <p class="business-card__desc">
          未経験からエンジニアを目指す方に向け、課題提出とフィードバックを軸にした伴走型の支援を行います。<br>
          自分で手を動かし、提出した成果に対して具体的なアドバイスを受けることで、着実に力を積み上げられる仕組みです。
        </p>
      </article>

    </div>
  </div>
</section>

<!-- demo の導線（画像：start-demo.png を使用） -->
<section class="section-lead section-lead--demo" aria-labelledby="demo-lead-title">
  <div class="section-lead__text">
    <h2 id="demo-lead-title" class="section-lead__title">まずは触って体験しよう！</h2>
    <p class="section-lead__desc">
      このDemoでは、Webシステムの基本要素に気軽に触れることができます。
    </p>
    <p class="section-lead__desc">
      フォームに入力したり、ボタンを押したり、色や形を変えてみたり――<br>
      身近な操作を通じて、Webシステムがどのように作られているのかを体感できます。
    </p>
  </div>
  <figure class="section-lead__media">
    <a href="/demo"><img
      src="/images/start-demo.png"
      alt="Web開発の体験デモを今すぐ開始｜START DEMO"
      width="1600" height="800" loading="lazy" decoding="async">
    </a>
  </figure>
</section>

<!-- blog の導線（画像：blog-hero.png を使用） -->
<section class="section-lead section-lead--blog" aria-labelledby="blog-lead-title">
  <div class="section-lead__text">
    <h2 id="blog-lead-title" class="section-lead__title">経営と学びのリアルを公開中</h2>
    <p class="section-lead__desc">
      代表の経営記録と、社員の学習の振り返りを発信しています。  
      成長のプロセスをそのまま見せることで、会社の雰囲気や姿勢が伝わるはずです。
    </p>
    <p class="section-lead__desc">
      これから挑戦する人の背中を押す、等身大の記録をぜひご覧ください。
    </p>
    <div class="section-lead__actions">
      <a href="/blog-list" class="btn-readmore">Blogを読む</a>
    </div>
  </div>

  <figure class="section-lead__media">
    <img
      src="/images/home-bloglead.png"
      alt="ノートとPCで日々の学びや経営の記録を残すイメージ｜Respoint Okinawa公式ブログ"
      width="1600" height="900" loading="lazy" decoding="async">
  </figure>
</section>


