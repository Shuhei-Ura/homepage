<section class="admin-container">
  <header class="admin-header">
    <h1 class="admin-title">
      {{#if isEdit }}
        ブログ編集
      {{else}}
        ブログ新規投稿
      {{/if}}
    </h1>
  </header>

  {{#if error}}<p class="error">{{error}}</p>{{/if}}

  <form method="POST" action="{{action}}" class="post-form">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">

    <div class="form-group">
      <label for="title">タイトル</label>
      <input id="title" name="title" type="text" required
             placeholder="タイトルを入力"
             value="{{post.title}}">
    </div>

    <div class="form-group">
      <label for="content">本文 (Markdown OK)</label>
      <textarea id="content" name="content" rows="12" required
                placeholder="本文を入力">{{post.content}}</textarea>
      <small class="hint">※ Markdownで保存します。公開時にHTMLへレンダリングします。</small>
    </div>

    <div class="button-row">
      <button type="submit" class="btn btn-primary">{{submitLabel}}</button>
      <a class="btn" href="/admin/posts-list">一覧へ戻る</a>
    </div>
  </form>
  <div class="admin-footer-nav">
    <a href="/admin" class="btn btn--menu">メニューへ</a>
  </div>
</section>
