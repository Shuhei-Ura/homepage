<section class="admin-container">
  <header class="admin-header">
    <h1 class="admin-title">お問い合わせ詳細</h1>
  </header>

  {{#if error}}<p class="error">{{error}}</p>{{/if}}

  <div class="contact-card">
    <div class="row">
      <div class="key">ID</div>
      <div class="val">{{contact.id}}</div>
    </div>
    <div class="row">
      <div class="key">受信日時</div>
      <div class="val">{{contact.created_at}}</div>
    </div>
    <div class="row">
      <div class="key">会社名</div>
      <div class="val">{{contact.company}}</div>
    </div>
    <div class="row">
      <div class="key">氏名</div>
      <div class="val">{{contact.name}}</div>
    </div>
    <div class="row">
      <div class="key">メール</div>
      <div class="val"><a href="mailto:{{contact.email}}" class="contact-mail">{{contact.email}}</a></div>
    </div>
    <div class="row">
      <div class="key">IP</div>
      <div class="val ip">{{contact.ip_address}}</div>
    </div>
    <div class="row">
      <div class="key">ステータス</div>
      <div class="val"><span class="badge {{contact.statusClass}}">{{contact.statusLabel}}</span></div>
    </div>
    <div class="row row-content">
      <div class="key">内容</div>
      <div class="val"><pre class="content">{{contact.content}}</pre></div>
    </div>
  </div>

  <!-- ステータス更新（任意。不要なら丸ごと削除OK） -->
  <form class="status-form" method="POST" action="/admin/contact/{{contact.id}}/status">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <label for="status" class="status-label">ステータス更新</label>
    <select id="status" name="status" class="status-select">
      <option value="0" {{#if contact.selected0}}selected{{/if}}>未対応</option>
      <option value="1" {{#if contact.selected1}}selected{{/if}}>対応中</option>
      <option value="2" {{#if contact.selected2}}selected{{/if}}>完了</option>
    </select>
    <button type="submit" class="btn">変更</button>
  </form>

  <div class="detail-actions">
    <a href="/admin/contacts-list" class="btn">一覧へ戻る</a>
    <a href="/admin" class="btn btn--menu">メニューへ</a>
  </div>
</section>
