<!-- About Hero -->
<section class="about-hero">
  <div class="about-hero__inner">
    <img src="/images/about-hero.png" alt="沖縄で未経験から成長する若手エンジニアを象徴する芽生えのイメージ" class="about-hero__bg">
    <div class="about-hero__text">
      <h2 class="about-hero__title">
        エンジニアが自らの価値を信じ<br>
        未来に希望を持てる
      </h2>
